# user-defined aliases (sourced by .bashrc)

# drop-in replacements
alias cat=bat
alias cd=z
alias grep=rg
alias ls='eza --icons=always'
alias ll='ls -la'
alias l.='ls -d .*'

alias ..='cd ..'
alias bc='bc -l'
alias mkdir='mkdir -pv'

alias h='history | less'
alias untar='tar -zxvf'

alias path='echo -e ${PATH//:/\\n}'
alias now='date +"%T"'
alias today='date +"%Y-%m-%d"'

alias ping='ping -c 5'
alias wget='wget -c'

# Meta specific
alias jfd='jf submit --draft'
alias ssh='x2ssh -et'
alias tt=taste-tester
