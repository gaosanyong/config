{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#073642",
          "foreground": "#93a1a1",
          "style": "powerline",
          "template": "{{ if .WSL }}WSL at{{ end }} {{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#0b4d6a",
          "foreground": "#839496",
          "powerline_symbol": "▌",
          "properties": {
            "style": "full"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#2a4a32",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#4a3520{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#4a2020{{ end }}",
            "{{ if gt .Ahead 0 }}#2d2a4a{{ end }}",
            "{{ if gt .Behind 0 }}#2d2a4a{{ end }}"
          ],
          "foreground": "#859900",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#cb4b16{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#dc322f{{ end }}",
            "{{ if gt .Ahead 0 }}#6c71c4{{ end }}",
            "{{ if gt .Behind 0 }}#6c71c4{{ end }}"
          ],
          "powerline_symbol": "▌",
          "properties": {
            "fetch_stash_count": true,
            "fetch_status": true,
            "branch_icon": " "
          },
          "style": "powerline",
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "#1a3a3a",
          "foreground": "#2aa198",
          "powerline_symbol": "▌",
          "properties": {
            "fetch_version": true
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "go"
        },
        {
          "background": "#2d2a4a",
          "foreground": "#6c71c4",
          "powerline_symbol": "▌",
          "properties": {
            "fetch_version": true
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "julia"
        },
        {
          "background": "#3a3010",
          "foreground": "#b58900",
          "powerline_symbol": "▌",
          "properties": {
            "display_mode": "files",
            "fetch_virtual_env": false
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "python"
        },
        {
          "background": "#4a2020",
          "foreground": "#dc322f",
          "powerline_symbol": "▌",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "ruby"
        },
        {
          "background": "#4a3520",
          "foreground": "#cb4b16",
          "powerline_symbol": "▌",
          "properties": {
            "display_mode": "files",
            "fetch_version": false
          },
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "azfunc"
        },
        {
          "background": "#3a3010",
          "foreground": "#b58900",
          "powerline_symbol": "▌",
          "style": "powerline",
          "template": "  ",
          "type": "root"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "final_space": true,
  "version": 3
}
