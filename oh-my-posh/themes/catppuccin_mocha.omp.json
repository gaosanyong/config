{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "#313244",
          "foreground": "#BAC2DE",
          "style": "powerline",
          "template": "{{ if .WSL }}WSL at{{ end }} {{.Icon}} ",
          "type": "os"
        },
        {
          "background": "#45475A",
          "foreground": "#89B4FA",
          "powerline_symbol": "",
          "properties": {
            "style": "full"
          },
          "style": "powerline",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "background": "#1e3a2e",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#3a2a1e{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#3a1e2e{{ end }}",
            "{{ if gt .Ahead 0 }}#2a1e3a{{ end }}",
            "{{ if gt .Behind 0 }}#2a1e3a{{ end }}"
          ],
          "foreground": "#A6E3A1",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#FAB387{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#F38BA8{{ end }}",
            "{{ if gt .Ahead 0 }}#CBA6F7{{ end }}",
            "{{ if gt .Behind 0 }}#CBA6F7{{ end }}"
          ],
          "powerline_symbol": "",
          "properties": {
            "fetch_stash_count": true,
            "fetch_status": true,
            "branch_icon": " "
          },
          "style": "powerline",
          "template": " {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}  {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}  {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} ",
          "type": "git"
        },
        {
          "background": "#1e3a3a",
          "foreground": "#94E2D5",
          "powerline_symbol": "",
          "properties": {
            "fetch_version": true
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "go"
        },
        {
          "background": "#2a1e3a",
          "foreground": "#CBA6F7",
          "powerline_symbol": "",
          "properties": {
            "fetch_version": true
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "julia"
        },
        {
          "background": "#3a3520",
          "foreground": "#F9E2AF",
          "powerline_symbol": "",
          "properties": {
            "display_mode": "files",
            "fetch_virtual_env": false
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "python"
        },
        {
          "background": "#3a1e2e",
          "foreground": "#F38BA8",
          "powerline_symbol": "",
          "properties": {
            "display_mode": "files",
            "fetch_version": true
          },
          "style": "powerline",
          "template": "  {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "ruby"
        },
        {
          "background": "#3a2a1e",
          "foreground": "#FAB387",
          "powerline_symbol": "",
          "properties": {
            "display_mode": "files",
            "fetch_version": false
          },
          "style": "powerline",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "type": "azfunc"
        },
        {
          "background": "#3a3520",
          "foreground": "#F9E2AF",
          "powerline_symbol": "",
          "style": "powerline",
          "template": "  ",
          "type": "root"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "final_space": true,
  "version": 3
}
